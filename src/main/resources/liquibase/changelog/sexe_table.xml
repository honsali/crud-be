<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <changeSet id="aff53f46-8084-3179-8df5-22472e3a745a-0" author="app_core">
        <createSequence sequenceName="seq_sexe" startValue="100" incrementBy="10" />
    </changeSet>
    <changeSet id="aff53f46-8084-3179-8df5-22472e3a745a-1" author="app_core">
        <createTable tableName="sexe">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false" />
            </column>
            <column name="libelle" type="nvarchar(250)">
                <constraints nullable="false" />
            </column>
            <column name="code" type="nvarchar(250)">
                <constraints nullable="false" />
            </column>
        </createTable>
    </changeSet>

    <changeSet id="aff53f46-8084-3179-8df5-22472e3a745a-data" author="app_core">
        <loadData
            file="liquibase/data/sexe.csv"
            separator=";"
            tableName="sexe"
            usePreparedStatements="true">
            <column name="id" type="numeric" />
            <column name="libelle" type="nvarchar(250)" />
            <column name="code" type="nvarchar(250)" />
        </loadData>
    </changeSet>
</databaseChangeLog>