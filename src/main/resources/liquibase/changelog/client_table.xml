<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <changeSet id="1357712437-0" author="app_core">
        <createSequence sequenceName="seq_client" startValue="100" incrementBy="10" />
    </changeSet>
    <changeSet id="1357712437-1" author="app_core">
        <createTable tableName="client">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false" />
            </column>
            <column name="raison_sociale" type="nvarchar(250)">
                <constraints nullable="true" />
            </column>
            <column name="siege_social" type="nvarchar(250)">
                <constraints nullable="true" />
            </column>
            <column name="rc" type="nvarchar(250)">
                <constraints nullable="true" />
            </column>
            <column name="cnss" type="nvarchar(250)">
                <constraints nullable="true" />
            </column>
            <column name="idf" type="nvarchar(250)">
                <constraints nullable="true" />
            </column>
            <column name="pte" type="nvarchar(250)">
                <constraints nullable="true" />
            </column>
            <column name="ice" type="nvarchar(250)">
                <constraints nullable="true" />
            </column>
            <column name="tel" type="nvarchar(250)">
                <constraints nullable="true" />
            </column>
            <column name="email" type="nvarchar(250)">
                <constraints nullable="true" />
            </column>
            <column name="site_web" type="nvarchar(250)">
                <constraints nullable="true" />
            </column>
        </createTable>
    </changeSet>

    <changeSet id="1357712437-data" author="app_core">
        <loadData
            file="liquibase/data/client.csv"
            separator=";"
            tableName="client"
            usePreparedStatements="true">
            <column name="id" type="numeric" />
            <column name="raison_sociale" type="nvarchar(250)" />
            <column name="siege_social" type="nvarchar(250)" />
            <column name="rc" type="nvarchar(250)" />
            <column name="cnss" type="nvarchar(250)" />
            <column name="idf" type="nvarchar(250)" />
            <column name="pte" type="nvarchar(250)" />
            <column name="ice" type="nvarchar(250)" />
            <column name="tel" type="nvarchar(250)" />
            <column name="email" type="nvarchar(250)" />
            <column name="site_web" type="nvarchar(250)" />
        </loadData>
    </changeSet>
</databaseChangeLog>