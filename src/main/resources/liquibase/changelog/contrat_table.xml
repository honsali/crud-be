<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <changeSet id="951542707-0" author="app_core">
        <createSequence sequenceName="seq_contrat" startValue="100" incrementBy="10" />
    </changeSet>
    <changeSet id="951542707-1" author="app_core">
        <createTable tableName="contrat">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false" />
            </column>
            <column name="date_accord" type="date">
                <constraints nullable="true" />
            </column>
            <column name="date_debut" type="date">
                <constraints nullable="true" />
            </column>
            <column name="date_fin" type="date">
                <constraints nullable="true" />
            </column>
            <column name="tjm" type="double">
                <constraints nullable="true" />
            </column>
            <column name="cnss" type="double">
                <constraints nullable="true" />
            </column>
            <column name="salaire_net" type="double">
                <constraints nullable="true" />
            </column>
            <column name="ressource_id" type="bigint">
                <constraints nullable="true" />
            </column>
            <column name="entreprise_id" type="bigint">
                <constraints nullable="true" />
            </column>
            <column name="type_contrat_id" type="bigint">
                <constraints nullable="true" />
            </column>
            <column name="etat_contrat_id" type="bigint">
                <constraints nullable="true" />
            </column>
            <column name="poste_id" type="bigint">
                <constraints nullable="true" />
            </column>
        </createTable>
    </changeSet>

    <changeSet id="951542707-data" author="app_core">
        <loadData
            file="liquibase/data/contrat.csv"
            separator=";"
            tableName="contrat"
            usePreparedStatements="true">
            <column name="id" type="numeric" />
            <column name="date_accord" type="date" />
            <column name="date_debut" type="date" />
            <column name="date_fin" type="date" />
            <column name="tjm" type="double" />
            <column name="cnss" type="double" />
            <column name="salaire_net" type="double" />
            <column name="entreprise_id" type="numeric" />
            <column name="type_contrat_id" type="numeric" />
            <column name="etat_contrat_id" type="numeric" />
            <column name="poste_id" type="numeric" />
        </loadData>
    </changeSet>
</databaseChangeLog>